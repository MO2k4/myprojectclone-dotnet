<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      Adds the local `./artifacts` directory as a NuGet feed.
      `dotnet pack tools/Quality.Cli` produces the dotnet-quality nupkg there,
      which lets `dotnet tool restore` pick it up without publishing to nuget.org.
      Inherited user-level feeds (e.g. nuget.org) remain active.
    -->
    <add key="local-artifacts" value="./artifacts" />
  </packageSources>
</configuration>
